@model IEnumerable<webclothes.Models.CartItem>
@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container py-5" style="min-height: 70vh;">
    <h2 class="mb-4 fw-bold text-center" style="letter-spacing: 1px;" data-aos="fade-down">XÁC NHẬN ĐƠN HÀNG</h2>

    <div class="row g-5">
        <div class="col-md-7" data-aos="fade-right">
            <div class="p-4 bg-white rounded shadow-sm border">
                <h4 class="mb-4 pb-2 border-bottom fw-bold"><i class="fa-solid fa-address-card me-2"></i> Thông tin giao hàng</h4>
                <form asp-action="Checkout" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và Tên</label>
                        <input type="text" name="customerName" class="form-control form-control-lg" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="tel" name="phone" class="form-control form-control-lg" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Email (để nhận hóa đơn)</label>
                            <input type="email" name="email" class="form-control form-control-lg" required />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Địa chỉ giao hàng</label>
                        <textarea name="address" class="form-control form-control-lg" rows="3" required></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold mb-3">Phương thức thanh toán</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="paymentCOD" value="COD" checked>
                            <label class="form-check-label" for="paymentCOD">
                                Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="paymentVNPAY" value="VNPAY">
                            <label class="form-check-label" for="paymentVNPAY">
                                Thanh toán trực tuyến qua VNPAY
                                <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/6/0oxhzjmxbksr1686814746087.png" alt="VNPay" height="24" class="ms-2" />
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-dark w-100 py-3 fw-bold fs-5 rounded-pill shadow">ĐẶT HÀNG NGAY <i class="fa-solid fa-arrow-right ms-2"></i></button>
                </form>
            </div>
        </div>

        <div class="col-md-5" data-aos="fade-left">
            <div class="p-4 rounded shadow-sm" style="background-color: #f8f9fa; border: 2px dashed #ddd;">
                <h4 class="mb-4 fw-bold"><i class="fa-solid fa-cart-shopping me-2"></i> Tóm tắt đơn hàng</h4>
                <ul class="list-group mb-3 list-group-flush bg-transparent">
                    @foreach (var item in Model)
                    {
                        <li class="list-group-item d-flex justify-content-between lh-sm bg-transparent border-bottom">
                            <div>
                                <h6 class="my-0">
                                    @item.ProductName
                                    @if (!string.IsNullOrEmpty(item.Size))
                                    {
                                        <span class="badge bg-secondary ms-1">@item.Size</span>
                                    }
                                </h6>
                                <small class="text-muted">Số lượng: @item.Quantity</small>
                            </div>
                            <span class="text-muted">@((item.Price * item.Quantity).ToString("N0")) đ</span>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between bg-transparent pt-3 border-0">
                        <span>Tạm tính</span>
                        <strong>@Model.Sum(x => x.Price * x.Quantity).ToString("N0") <small>đ</small></strong>
                    </li>
                    
                    @if (ViewBag.Discount != null)
                    {
                        <li class="list-group-item d-flex justify-content-between bg-transparent border-0 text-success">
                            <span>Giảm giá (Mã: @ViewBag.VoucherCode)</span>
                            <strong>- @(((decimal)ViewBag.Discount).ToString("N0")) <small>đ</small></strong>
                        </li>
                    }

                    <li class="list-group-item d-flex justify-content-between bg-transparent fw-bold fs-5 pt-3 border-top">
                        <span>Tổng cộng (VNĐ)</span>
                        @{
                            decimal totalAmount = Model.Sum(x => x.Price * x.Quantity);
                            decimal discountAmount = ViewBag.Discount != null ? (decimal)ViewBag.Discount : 0;
                            if (discountAmount > totalAmount) discountAmount = totalAmount;
                            decimal finalTotal = totalAmount - discountAmount;
                        }
                        <strong>@finalTotal.ToString("N0") <small>đ</small></strong>
                    </li>
                </ul>

                <hr class="my-4" />
                <h5 class="mb-3 fw-bold"><i class="fa-solid fa-ticket me-2"></i> Mã giảm giá</h5>
                <form asp-action="ApplyVoucher" method="post" class="d-flex gap-2 mb-3">
                    <input type="text" name="code" class="form-control" placeholder="Nhập mã voucher (VD: GIAM50K)" required />
                    <button type="submit" class="btn btn-secondary">Áp dụng</button>
                </form>
                @if (TempData["VoucherError"] != null)
                {
                    <div class="text-danger small mt-2"><i class="fa-solid fa-triangle-exclamation"></i> @TempData["VoucherError"]</div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="text-success small mt-2"><i class="fa-solid fa-check-circle"></i> @TempData["SuccessMessage"]</div>
                }
            </div>
        </div>
    </div>
</div>