@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@model IdentityUser
@{
    ViewData["Title"] = "Hồ sơ của tôi";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar Profile -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius: 15px;">
                <div class="mb-3">
                    <img src="https://ui-avatars.com/api/?name=@(User.Identity?.Name)&background=0D8ABC&color=fff&size=128" 
                         class="rounded-circle shadow-sm" alt="Avatar">
                </div>
                <h4 class="fw-bold mb-1">@User.Identity?.Name</h4>
                <p class="text-muted small mb-4">@User.Identity?.Name</p>

                <div class="text-start p-3 rounded" style="background: #f8f9fa;">
                    <div class="text-uppercase small fw-bold text-muted mb-2">Thông tin tài khoản</div>
                    <div class="mb-2">
                        <span class="text-muted small">User ID:</span> 
                        <div class="text-break small">@UserManager.GetUserId(User)</div>
                    </div>
                    <div class="mb-2">
                        <span class="text-muted small">Email xác thực:</span>
                        <span class="badge @(User.Identity?.IsAuthenticated == true ? "bg-success" : "bg-warning text-dark") ms-1">
                            @(User.Identity?.IsAuthenticated == true ? "Đã xác thực" : "Chưa xác thực")
                        </span>
                    </div>
                    <div>
                        <span class="text-muted small">Số điện thoại:</span>
                        <span class="ms-1 small">Chưa cập nhật</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Orders -->
        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4" style="border-radius: 15px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0"><i class="fas fa-history me-2"></i>Đơn hàng gần đây</h5>
                    <a href="/Orders/History" class="btn btn-sm btn-outline-dark rounded-pill px-3">Xem tất cả</a>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn</th>
                                <th>Ngày đặt</th>
                                <th>Trạng thái</th>
                                <th>Tổng tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentOrders != null)
                            {
                                foreach (var order in (List<webclothes.Models.Order>)ViewBag.RecentOrders)
                                {
                                    <tr>
                                        <td><a href="/Orders/Details/@order.Id" class="fw-bold text-decoration-none">#@order.Id</a></td>
                                        <td class="small">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @{
                                                var badgeClass = order.Status switch {
                                                    "Hoàn thành" => "bg-success",
                                                    "Hủy đơn hàng" => "bg-danger",
                                                    "Đang giao hàng" => "bg-info",
                                                    _ => "bg-warning text-dark"
                                                };
                                            }
                                            <span class="badge @badgeClass" style="font-size: 0.75rem;">@order.Status</span>
                                        </td>
                                        <td class="fw-bold">@order.TotalAmount.ToString("N0") đ</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-4 text-muted">Bạn chưa có đơn hàng nào.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
