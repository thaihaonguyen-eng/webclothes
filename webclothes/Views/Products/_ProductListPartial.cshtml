@model IEnumerable<webclothes.Models.Product>

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<div class="row g-4" id="product-grid-content">
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 col-sm-6" data-aos="fade-up">
                <div class="product-card h-100 position-relative shadow-sm rounded overflow-hidden">
                    @if (item.StockQuantity <= 0)
                    {
                        <div class="position-absolute w-100 h-100 d-flex justify-content-center align-items-center" style="background: rgba(255,255,255,0.7); z-index: 10;">
                            <span class="badge bg-danger fs-5 px-4 py-2 text-uppercase" style="transform: rotate(-15deg);">HẾT HÀNG</span>
                        </div>
                    }

                    <div class="product-img-wrapper" style="padding-top: 100%;">
                        @if (item.IsOnSale)
                        {
                            <span class="position-absolute top-0 start-0 m-2 badge bg-danger rounded-pill px-2 py-1" style="z-index:11; font-size:0.7rem;">SALE -@(Math.Round((1 - item.SalePrice!.Value / item.Price) * 100))%</span>
                        }
                        @if (!string.IsNullOrEmpty(item.MainImageUrl))
                        {
                            <img src="@item.MainImageUrl" alt="@item.Name" loading="lazy" />
                        }
                        else
                        {
                            <img src="https://images.unsplash.com/photo-1515347619253-122cb41a4a16?q=80&w=600&auto=format&fit=crop" alt="@item.Name" loading="lazy" />
                        }
                    </div>

                    <div class="product-info py-3 px-2">
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@(item.Slug ?? item.Id.ToString())" class="product-title text-truncate d-block">
                            @item.Name
                        </a>
                        <div class="product-price mb-2 text-danger fw-bold">
                            @if (item.IsOnSale)
                            {
                                <span class="text-decoration-line-through text-muted me-1" style="font-size: 0.75rem; font-weight: normal;">@item.Price.ToString("N0")</span>
                                @item.DisplayPrice.ToString("N0") <span style="font-size: 0.8rem;">VND</span>
                            }
                            else
                            {
                                @item.Price.ToString("N0") <span style="font-size: 0.8rem;">VND</span>
                            }
                        </div>

                        @if (item.StockQuantity > 0)
                        {
                            <button type="button" class="btn btn-dark btn-sm w-100 btn-add-cart rounded-pill" data-id="@item.Id">
                                <i class="fa-solid fa-cart-plus me-2"></i> THÊM VÀO GIỎ
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-secondary btn-sm w-100 rounded-pill" disabled>
                                <i class="fa-solid fa-times-circle me-2"></i> HẾT HÀNG
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="fa-solid fa-box-open fa-3x text-muted mb-3"></i>
            <h4 class="text-muted">Không tìm thấy sản phẩm nào phù hợp.</h4>
        </div>
    }
</div>

@if (totalPages > 1)
{
    <nav class="mt-5" aria-label="Phân trang sản phẩm">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link ajax-page-link" href="#" data-page="@(currentPage - 1)">Trước</a>
            </li>

            @for (int p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p == currentPage ? "active" : "")">
                    <a class="page-link ajax-page-link" href="#" data-page="@p">@p</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link ajax-page-link" href="#" data-page="@(currentPage + 1)">Sau</a>
            </li>
        </ul>
    </nav>
}
