@model webclothes.Models.Product

@{
    ViewData["Title"] = Model.Name;
    var relatedProducts = ViewBag.RelatedProducts as List<webclothes.Models.Product>;
}

<div class="bg-light py-4 mb-5">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/" class="text-dark text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-dark text-decoration-none">@(Model.Category?.Name ?? "Sản phẩm")</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container pb-5 mb-5">
    <div class="row g-5">
        <!-- Ảnh sản phẩm -->
        <div class="col-md-6" data-aos="fade-right">
            <div class="border rounded px-4 py-5 bg-white position-relative text-center shadow-sm" style="height: 600px; display: flex; align-items: center; justify-content: center;">
                @if (Model.Price < 500000)
                {
                    <span class="badge bg-danger position-absolute top-0 start-0 m-3 px-3 py-2 rounded-pill" style="z-index: 2;">HOT</span>
                }
                
                @if (!string.IsNullOrEmpty(Model.ImageName))
                {
                    <img src="~/images/products/@Model.ImageName" alt="@Model.Name" class="img-fluid" style="max-height: 100%; object-fit: contain; zoom: 1.2;" />
                }
                else
                {
                    <img src="https://images.unsplash.com/photo-1515347619253-122cb41a4a16?q=80&w=600&auto=format&fit=crop" alt="@Model.Name" class="img-fluid" style="max-height: 100%; object-fit: contain;" />
                }
            </div>
        </div>

        <!-- Thông tin chi tiết -->
        <div class="col-md-6" data-aos="fade-left">
            <h1 class="fw-bold mb-3" style="font-size: 2.5rem; letter-spacing: -1px;">@Model.Name</h1>
            
            <div class="d-flex align-items-center mb-4 pb-4 border-bottom">
                <div class="text-danger fw-bold fs-2 me-4">
                    @Model.Price.ToString("N0") <span class="fs-4">VNĐ</span>
                </div>
                <div>
                    <i class="fa-solid fa-star text-warning"></i>
                    <i class="fa-solid fa-star text-warning"></i>
                    <i class="fa-solid fa-star text-warning"></i>
                    <i class="fa-solid fa-star text-warning"></i>
                    <i class="fa-solid fa-star-half-stroke text-warning"></i>
                    <span class="text-muted ms-2">(129 đánh giá)</span>
                </div>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold mb-3">Mô tả sản phẩm</h5>
                <p class="text-muted lh-lg" style="font-size: 1.1rem; min-height: 120px;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Mang lại trải nghiệm thời trang tuyệt vời với chất liệu cao cấp và kiểu dáng hiện đại. Phù hợp cho mọi sự kiện từ công sở đến dạo phố." : Model.Description)
                </p>
                <ul class="list-unstyled text-muted mt-3">
                    <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i> Chất liệu nhập khẩu cao cấp</li>
                    <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i> Thiết kế form dáng chuẩn mực</li>
                    <li class="mb-2"><i class="fa-solid fa-check text-success me-2"></i> Đường may tỉ mỉ, tinh tế</li>
                </ul>
            </div>

            <div class="d-flex gap-3 mt-5">
                <button type="button" class="btn btn-dark btn-lg px-5 py-3 fw-bold rounded-pill btn-add-cart flex-grow-1 shadow" data-id="@Model.Id" style="letter-spacing: 1px;">
                    <i class="fa-solid fa-cart-shopping me-2"></i> THÊM VÀO GIỎ
                </button>
                <button class="btn btn-outline-danger btn-lg px-4 rounded-circle" aria-label="Yêu thích" title="Thêm vào yêu thích">
                    <i class="fa-regular fa-heart"></i>
                </button>
            </div>
            
            <div class="mt-5 border p-4 rounded bg-light">
                <div class="d-flex mb-3">
                    <div class="fs-4 text-dark me-3"><i class="fa-solid fa-truck-fast"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1">Giao hàng miễn phí</h6>
                        <small class="text-muted">Áp dụng cho mọi đơn hàng toàn quốc.</small>
                    </div>
                </div>
                <div class="d-flex">
                    <div class="fs-4 text-dark me-3"><i class="fa-solid fa-rotate-left"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1">Đổi trả miễn phí</h6>
                        <small class="text-muted">Đổi trả nhanh chóng trong 30 ngày nếu không vừa ý.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lưới sản phẩm liên quan -->
@if (relatedProducts != null && relatedProducts.Any())
{
    <div class="container mb-5 pb-5 border-top pt-5">
        <h3 class="fw-bold mb-4 text-center">SẢN PHẨM CÙNG DANH MỤC</h3>
        <div class="row g-4">
            @foreach (var item in relatedProducts)
            {
                <div class="col-lg-3 col-md-4 col-sm-6" data-aos="fade-up">
                    <div class="product-card h-100 border-0 shadow-sm">
                        <div class="product-img-wrapper" style="padding-top: 100%;">
                            @if (!string.IsNullOrEmpty(item.ImageName))
                            {
                                <img src="~/images/products/@item.ImageName" alt="@item.Name" loading="lazy" />
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1515347619253-122cb41a4a16?q=80&w=600&auto=format&fit=crop" alt="@item.Name" loading="lazy" />
                            }
                        </div>

                        <div class="product-info py-3">
                            <a asp-action="Details" asp-route-id="@item.Id" class="product-title">@item.Name</a>
                            <div class="product-price mb-2">@item.Price.ToString("N0") VNĐ</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.querySelectorAll('.btn-add-cart').forEach(button => {
            button.addEventListener('click', function() {
                let productId = this.getAttribute('data-id');
                const btn = this;
                
                let originalContent = btn.innerHTML;
                btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> ĐANG XỬ LÝ...`;
                btn.disabled = true;

                let formData = new FormData();
                formData.append('productId', productId);

                fetch('@Url.Action("AddToCartAjax", "Cart")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    btn.innerHTML = originalContent;
                    btn.disabled = false;

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });

                        let cartCounter = document.getElementById('cart-counter');
                        if(cartCounter) {
                            cartCounter.innerText = data.cartCount;
                            cartCounter.style.transform = "scale(1.3)";
                            setTimeout(() => cartCounter.style.transform = "scale(1) translate(-50%, -50%)", 300);
                        }
                    } else {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message });
                    }
                })
                .catch(error => {
                    btn.innerHTML = originalContent;
                    btn.disabled = false;
                    console.error('Error:', error);
                });
            });
        });
    </script>
}
