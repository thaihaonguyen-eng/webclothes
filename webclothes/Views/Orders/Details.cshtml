@model webclothes.Models.Order
@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container py-5" style="min-height: 70vh;" data-aos="fade-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Chi tiết Đơn hàng #@Model.Id</h2>
        <a asp-action="History" class="btn btn-outline-dark rounded-pill px-4"><i class="fa-solid fa-arrow-left me-2"></i> Quay lại</a>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4 bg-light">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin khách hàng</h5>
                    <p class="mb-1"><strong>Tên:</strong> @Model.CustomerName</p>
                    <p class="mb-1"><strong>SĐT:</strong> @Model.Phone</p>
                    <p class="mb-1"><strong>Địa chỉ:</strong> @Model.Address</p>
                    <p class="mb-1"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
            </div>
            
            <div class="card border-0 shadow-sm rounded-3 mt-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 border-bottom pb-2">Trạng thái</h5>
                    @if (Model.Status == "Chờ xử lý")
                    {
                        <div class="alert alert-warning mb-0 border-0 fw-bold"><i class="fa-solid fa-clock me-2"></i> @Model.Status</div>
                    }
                    else if (Model.Status == "Đang giao")
                    {
                        <div class="alert alert-info mb-0 border-0 fw-bold"><i class="fa-solid fa-truck-fast me-2"></i> @Model.Status</div>
                    }
                    else 
                    {
                        <div class="alert alert-success mb-0 border-0 fw-bold"><i class="fa-solid fa-check me-2"></i> @Model.Status</div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4 border-bottom pb-2">Danh sách Sản phẩm</h5>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Đơn giá</th>
                                    <th>Số lượng</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="fw-bold">@detail.Product.Name</td>
                                        <td>@detail.Price.ToString("N0") đ</td>
                                        <td>@detail.Quantity</td>
                                        <td class="fw-bold text-danger">@((detail.Price * detail.Quantity).ToString("N0")) đ</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold" style="font-size: 1.1rem;">
                                <tr>
                                    <td colspan="3" class="text-end">Tổng cộng:</td>
                                    <td class="text-danger">@Model.TotalAmount.ToString("N0") đ</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
