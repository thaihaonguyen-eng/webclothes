@model IEnumerable<webclothes.Models.Product>

@{
    ViewData["Title"] = "Trang chủ";
}

<div class="hero-banner">
    <div class="container">
        <h1 data-aos="fade-down">BỘ SƯU TẬP MÙA HÈ</h1>
        <p data-aos="fade-up" data-aos-delay="200">Khám phá sự thanh lịch tối giản với các thiết kế mới nhất dành cho năm nay. Chất liệu cao cấp, form dáng chuẩn mực, tôn vinh đẳng cấp cá nhân.</p>
        <a href="#product-section" class="btn btn-light rounded-pill px-5 py-3 mt-3 fw-bold shadow-lg" data-aos="zoom-in" data-aos-delay="400" style="letter-spacing: 1px; color: var(--primary-color);">
            KHÁM PHÁ NGAY
        </a>
    </div>
</div>

<div class="container mb-5" id="product-section">
    <div class="d-flex justify-content-between align-items-end mb-5 border-bottom pb-3" data-aos="fade-right">
        <div>
            <span class="text-uppercase" style="color: var(--secondary-color); font-weight: 600; letter-spacing: 2px;">Trending Now</span>
            <h2 class="mb-0 fw-bold" style="font-size: 2.2rem; letter-spacing: -1px;">Sản phẩm nổi bật</h2>
        </div>
    </div>

    <div class="row g-4 pb-5">
        @if(Model != null && Model.Any())
        {
            int delay = 0;
            @foreach (var item in Model)
            {
                <div class="col-lg-3 col-md-4 col-sm-6" data-aos="fade-up" data-aos-delay="@delay">
                    <div class="product-card h-100">
                        <div class="product-img-wrapper">
                            @if (!string.IsNullOrEmpty(item.ImageName))
                            {
                                <img src="~/images/products/@item.ImageName" alt="@item.Name" loading="lazy" />
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1515347619253-122cb41a4a16?q=80&w=600&auto=format&fit=crop" alt="@item.Name" loading="lazy" />
                            }

                            @if (item.Price < 500000)
                            {
                                <span class="badge-custom">HOT</span>
                            }
                        </div>

                        <div class="product-info">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="product-title">
                                @item.Name
                            </a>
                            <div class="product-price">
                                @item.Price.ToString("N0") <span style="font-size: 0.8rem;">VNĐ</span>
                            </div>

                            <!-- Button triggers the ajax event binding in Layout/Index scripts -->
                            <button type="button" class="btn-buy btn-add-cart w-100" data-id="@item.Id">
                                <i class="fa-solid fa-cart-plus me-2"></i> Thêm vào giỏ
                            </button>
                        </div>
                    </div>
                </div>
                delay += 100;
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fa-solid fa-box-open fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">Chưa có sản phẩm nào.</h4>
            </div>
        }
    </div>
</div>

<!-- Khối Chính sách dịch vụ -->
<div class="bg-white py-5 mt-4" data-aos="fade-up">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3 col-sm-6">
                <div class="p-4 border-end border-sm-0 h-100 feature-block">
                    <i class="fa-solid fa-truck-fast text-dark mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Giao hàng miễn phí</h5>
                    <p class="text-muted mb-0 small">Áp dụng cho mọi đơn hàng toàn quốc từ 500k.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="p-4 border-end border-sm-0 h-100 feature-block">
                    <i class="fa-solid fa-rotate-left text-dark mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Đổi trả 30 ngày</h5>
                    <p class="text-muted mb-0 small">Hoàn tiền hoặc đổi size 100% không lý do.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="p-4 border-end border-sm-0 h-100 feature-block">
                    <i class="fa-solid fa-shield-halved text-dark mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Thanh toán an toàn</h5>
                    <p class="text-muted mb-0 small">Bảo mật thông tin giao dịch thẻ qua VietQR.</p>
                </div>
            </div>
            <div class="col-md-3 col-sm-6">
                <div class="p-4 h-100 feature-block">
                    <i class="fa-solid fa-headset text-dark mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">Hỗ trợ 24/7</h5>
                    <p class="text-muted mb-0 small">Đội ngũ CSKH chuyên nghiệp luôn sẵn sàng.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Banner Khuyến Mãi Giữa Trang -->
<div class="mid-banner my-5" style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1445205170230-053b83016050?q=80&w=1500&auto=format&fit=crop') center/cover; padding: 100px 0; color: white; text-align: center;" data-aos="zoom-in">
    <div class="container">
        <h2 class="fw-bold mb-3" style="font-size: 3rem; letter-spacing: 2px;">WINTER COLLECTION 2026</h2>
        <p class="mb-4 fs-5 fw-light">Giảm giá lên đến 40% cho các sản phẩm len và áo khoác thời thượng.</p>
        <a href="#product-section" class="btn btn-outline-light rounded-pill px-5 py-2 fw-bold" style="letter-spacing: 1px;">SĂN DEAL NGAY</a>
    </div>
</div>

<!-- Đăng ký nhận tin -->
<div class="newsletter-section py-5 bg-light" data-aos="fade-up">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <h3 class="fw-bold mb-3">ĐĂNG KÝ NHẬN BẢN TIN</h3>
                <p class="text-muted mb-4">Nhận ngay thông tin về bộ sưu tập mới và các chương trình ưu đãi độc quyền dành riêng cho khách hàng VIP của chúng tôi.</p>
                <form class="d-flex justify-content-center gap-2 max-w-md mx-auto" style="max-width: 500px; margin: 0 auto;">
                    <input type="email" class="form-control rounded-pill px-4 py-3" placeholder="Nhập địa chỉ email của bạn..." required>
                    <button type="button" class="btn btn-dark rounded-pill px-4 fw-bold" onclick="alert('Cảm ơn bạn đã đăng ký nhận tin!')">ĐĂNG KÝ</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Ajax Add To Cart Logic
        document.querySelectorAll('.btn-add-cart').forEach(button => {
            button.addEventListener('click', function() {
                let productId = this.getAttribute('data-id');
                const btn = this;
                
                // Hiệu ứng loading nhỏ
                let originalContent = btn.innerHTML;
                btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin"></i> Đang xử lý...`;
                btn.disabled = true;

                let formData = new FormData();
                formData.append('productId', productId);

                fetch('@Url.Action("AddToCartAjax", "Cart")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    btn.innerHTML = originalContent;
                    btn.disabled = false;

                    if (data.success) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: data.message,
                            timer: 2000,
                            showConfirmButton: false,
                            toast: true,
                            position: 'top-end'
                        });

                        // Cập nhật số lượng
                        let cartCounter = document.getElementById('cart-counter');
                        if(cartCounter) {
                            cartCounter.innerText = data.cartCount;
                            
                            // Hiệu ứng zoom nhẹ cho icon giỏ hàng
                            cartCounter.style.transform = "scale(1.3)";
                            setTimeout(() => cartCounter.style.transform = "scale(1) translate(-50%, -50%)", 300);
                        }
                    } else {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message });
                    }
                })
                .catch(error => {
                    btn.innerHTML = originalContent;
                    btn.disabled = false;
                    console.error('Error:', error);
                });
            });
        });
    </script>
}