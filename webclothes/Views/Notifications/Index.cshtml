@model IEnumerable<webclothes.Models.Notification>

@{
    ViewData["Title"] = "Thông báo";

    if (User.IsInRole("Admin"))
    {
        Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    }
    else if (User.IsInRole("Seller"))
    {
        Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
    }
    else if (User.IsInRole("Shipper"))
    {
        Layout = "~/Areas/Shipper/Views/Shared/_ShipperLayout.cshtml";
    }
}

<div class="container py-4 py-lg-5" style="min-height: 70vh;">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="fa-solid fa-bell me-2"></i>Thông báo
            </h2>
            <p class="text-muted mb-0">Cập nhật đơn hàng, nhắc việc và các thay đổi mới nhất.</p>
        </div>

        @if (Model.Any(n => !n.IsRead))
        {
            <form asp-action="MarkAllRead" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-dark rounded-pill px-4">
                    Đánh dấu đã đọc tất cả
                </button>
            </form>
        }
    </div>

    @if (Model.Any())
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var item in Model)
            {
                var borderColor = item.Type switch
                {
                    "success" => "#10b981",
                    "warning" => "#f59e0b",
                    "danger" => "#ef4444",
                    _ => "#2563eb"
                };

                <div class="card border-0 shadow-sm" style="border-left: 5px solid @borderColor; opacity: @(item.IsRead ? "0.78" : "1");">
                    <div class="card-body">
                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <h5 class="mb-0 fw-bold">@item.Title</h5>
                                    @if (!item.IsRead)
                                    {
                                        <span class="badge rounded-pill text-bg-primary">Mới</span>
                                    }
                                </div>

                                @if (!string.IsNullOrWhiteSpace(item.Message))
                                {
                                    <p class="text-muted mb-2">@item.Message</p>
                                }

                                <small class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>

                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                @if (!string.IsNullOrWhiteSpace(item.LinkUrl))
                                {
                                    <a href="@item.LinkUrl" class="btn btn-sm btn-dark rounded-pill px-3">Xem</a>
                                }

                                @if (!item.IsRead)
                                {
                                    <form asp-action="MarkRead" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                            Đã đọc
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-light rounded-4">
            <i class="fa-regular fa-bell-slash fs-1 text-muted mb-3"></i>
            <h4 class="text-muted mb-1">Chưa có thông báo nào</h4>
            <p class="text-muted mb-0">Khi có cập nhật mới, hệ thống sẽ hiển thị ở đây.</p>
        </div>
    }
</div>
