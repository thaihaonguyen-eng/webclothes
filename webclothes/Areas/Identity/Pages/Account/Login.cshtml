@page
@model webclothes.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="auth-card w-100" style="max-width: 450px;" data-aos="fade-up">
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: var(--primary-color);">ĐĂNG NHẬP</h2>
            <p class="text-muted">Chào mừng bạn trở lại với Webclothes</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
            
            <div class="mb-3 form-floating">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <div class="mb-3 form-floating">
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            
            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label text-muted" asp-for="Input.RememberMe">
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
            </div>
            
            <button id="login-submit" type="submit" class="btn btn-dark w-100 py-3 rounded-pill fw-bold" style="letter-spacing: 1px;">ĐĂNG NHẬP</button>
            
            <div class="text-center mt-4">
                <p class="text-muted mb-2"><a id="forgot-password" asp-page="./ForgotPassword" class="text-dark text-decoration-none">Quên mật khẩu?</a></p>
                <p class="text-muted mb-0">Chưa có tài khoản? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-dark fw-bold text-decoration-none">Đăng ký ngay</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
