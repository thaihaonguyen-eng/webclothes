@page
@model webclothes.Areas.Identity.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="auth-card w-100" style="max-width: 450px;" data-aos="fade-up">
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: var(--primary-color);">QUÊN MẬT KHẨU</h2>
            <p class="text-muted">Nhập tên đăng nhập và email để nhận mật khẩu mới.</p>
        </div>

        @if (Model.StatusMessage != null)
        {
            <div class="alert alert-info" role="alert">
                @Model.StatusMessage
            </div>
        }

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="mb-3 form-floating">
                <input asp-for="Input.UserName" class="form-control" autocomplete="username" aria-required="true" placeholder="Tên đăng nhập" />
                <label asp-for="Input.UserName" class="form-label">Tên đăng nhập</label>
                <span asp-validation-for="Input.UserName" class="text-danger"></span>
            </div>

            <div class="mb-4 form-floating">
                <input asp-for="Input.Email" class="form-control" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                <label asp-for="Input.Email" class="form-label">Email (Gmail)</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn btn-dark w-100 py-3 rounded-pill fw-bold" style="letter-spacing: 1px;">GỬI MẬT KHẨU MỚI</button>
            
            <div class="text-center mt-4">
                <p class="text-muted mb-0">Nhớ mật khẩu? <a asp-page="./Login" class="text-dark fw-bold text-decoration-none">Đăng nhập ngay</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
