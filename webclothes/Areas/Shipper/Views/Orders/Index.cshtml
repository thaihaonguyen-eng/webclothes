@model IEnumerable<webclothes.Models.Order>
@{
    ViewData["Title"] = "Đơn cần giao";
    Layout = "~/Areas/Shipper/Views/Shared/_ShipperLayout.cshtml";
    var currentFilter = ViewBag.CurrentFilter as string ?? "all";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h4 class="fw-bold mb-4" style="color: #064e3b;">
    <i class="fas fa-boxes-stacked me-2"></i>Đơn hàng cần giao
</h4>

<!-- Bộ lọc trạng thái -->
<div class="mb-4 d-flex gap-2 flex-wrap">
    <a href="/Shipper/Orders?filter=all" 
       class="btn btn-sm @(currentFilter == "all" ? "text-white" : "btn-outline-secondary")"
       style="@(currentFilter == "all" ? "background: linear-gradient(135deg, #0d7377, #2ecc71); border: none;" : "")">
        Tất cả
    </a>
    <a href="/Shipper/Orders?filter=Chờ lấy hàng" 
       class="btn btn-sm @(currentFilter == "Chờ lấy hàng" ? "text-white" : "btn-outline-warning")"
       style="@(currentFilter == "Chờ lấy hàng" ? "background: #f59e0b; border-color: #f59e0b;" : "")">
        <i class="fas fa-box me-1"></i> Chờ lấy hàng
    </a>
    <a href="/Shipper/Orders?filter=Đang giao hàng" 
       class="btn btn-sm @(currentFilter == "Đang giao hàng" ? "text-white" : "btn-outline-info")"
       style="@(currentFilter == "Đang giao hàng" ? "background: #0ea5e9; border-color: #0ea5e9;" : "")">
        <i class="fas fa-truck me-1"></i> Đang giao
    </a>
    <a href="/Shipper/Orders?filter=Hoàn thành" 
       class="btn btn-sm @(currentFilter == "Hoàn thành" ? "text-white" : "btn-outline-success")"
       style="@(currentFilter == "Hoàn thành" ? "background: #10b981; border-color: #10b981;" : "")">
        <i class="fas fa-check me-1"></i> Hoàn thành
    </a>
    <a href="/Shipper/Orders?filter=Thất bại" 
       class="btn btn-sm @(currentFilter == "Thất bại" ? "text-white" : "btn-outline-danger")"
       style="@(currentFilter == "Thất bại" ? "background: #ef4444; border-color: #ef4444;" : "")">
        <i class="fas fa-times me-1"></i> Thất bại
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle text-center">
        <thead>
            <tr style="background: linear-gradient(135deg, #064e3b, #0d7377); color: white;">
                <th style="border-radius: 8px 0 0 0;">Mã ĐH</th>
                <th>Khách hàng</th>
                <th>SĐT</th>
                <th class="text-start">Địa chỉ</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th style="border-radius: 0 8px 0 0;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var badgeColor = item.Status switch
                {
                    "Chờ lấy hàng" => "#f59e0b",
                    "Đang giao hàng" => "#0ea5e9",
                    "Hoàn thành" => "#10b981",
                    "Thất bại" => "#ef4444",
                    _ => "#6b7280"
                };
                <tr>
                    <td><strong>#@item.Id</strong></td>
                    <td>@item.CustomerName</td>
                    <td>@item.Phone</td>
                    <td class="text-start text-muted" style="max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        <i class="fas fa-map-marker-alt me-1" style="color: #ef4444;"></i>@item.Address
                    </td>
                    <td class="fw-bold" style="color: #dc2626;">@item.TotalAmount.ToString("N0") đ</td>
                    <td>
                        <span class="badge rounded-pill text-white" style="background: @badgeColor;">@item.Status</span>
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">
                            <i class="fas fa-eye"></i> Xem
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-inbox" style="font-size: 3rem; opacity: 0.3;"></i>
        <p class="mt-3">Không có đơn hàng nào</p>
    </div>
}
