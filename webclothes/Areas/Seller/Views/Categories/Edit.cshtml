@model webclothes.Models.Category
@{
    ViewData["Title"] = "Sửa danh mục";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #4a90d9, #1e3a5f);">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Chỉnh sửa danh mục</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">Tên danh mục</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-3">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="form-group mb-4">
                        <label class="form-label fw-semibold">Danh mục cha (Tùy chọn)</label>
                        <select asp-for="ParentCategoryId" class="form-select">
                            <option value="">-- Thuộc danh mục gốc --</option>
                            @if (ViewBag.ParentCategories != null)
                            {
                                foreach (var parent in (List<webclothes.Models.Category>)ViewBag.ParentCategories)
                                {
                                    <option value="@parent.Id">@parent.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn text-white px-4" style="background: linear-gradient(135deg, #1e3a5f, #4a90d9); border: none;">
                            <i class="fa fa-save me-1"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
