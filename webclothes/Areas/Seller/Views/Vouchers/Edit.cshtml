@model webclothes.Models.Voucher
@{
    ViewData["Title"] = "Sửa Voucher";
    Layout = "~/Areas/Seller/Views/Shared/_SellerLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 12px; overflow: hidden;">
            <div class="card-header text-white py-3" style="background: linear-gradient(135deg, #4a90d9, #1e3a5f);">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Chỉnh sửa Voucher</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit">
                    <input type="hidden" asp-for="Id" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Mã Voucher <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" style="text-transform: uppercase; font-family: monospace; font-weight: bold;" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Loại giảm giá <span class="text-danger">*</span></label>
                        <select asp-for="DiscountType" class="form-select" id="discountTypeEdit" onchange="toggleEdit()">
                            <option value="Fixed">Giảm số tiền cố định (VNĐ)</option>
                            <option value="Percent">Giảm theo % đơn hàng</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" id="discountLabelEdit">Số tiền giảm <span class="text-danger">*</span></label>
                        <input asp-for="DiscountAmount" type="number" class="form-control" required min="0" />
                    </div>
                    <div class="mb-3" id="maxDiscountEdit" style="display:none;">
                        <label class="form-label fw-semibold">Giảm tối đa (VNĐ)</label>
                        <input asp-for="MaxDiscount" type="number" class="form-control" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Đơn tối thiểu (VNĐ)</label>
                        <input asp-for="MinOrderAmount" type="number" class="form-control" min="0" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Số lượng <span class="text-danger">*</span></label>
                        <input asp-for="Quantity" type="number" class="form-control" required min="0" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Ngày hết hạn <span class="text-danger">*</span></label>
                        <input asp-for="ExpiryDate" type="date" class="form-control" required />
                    </div>
                    <script>
                        function toggleEdit() {
                            var t = document.getElementById('discountTypeEdit').value;
                            document.getElementById('maxDiscountEdit').style.display = t === 'Percent' ? 'block' : 'none';
                            document.getElementById('discountLabelEdit').innerHTML = t === 'Percent' ? '% Giảm giá <span class="text-danger">*</span>' : 'Số tiền giảm (VNĐ) <span class="text-danger">*</span>';
                        }
                        toggleEdit();
                    </script>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn text-white px-4" style="background: linear-gradient(135deg, #1e3a5f, #4a90d9); border: none;">
                            <i class="fa fa-save me-1"></i> Cập nhật
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
