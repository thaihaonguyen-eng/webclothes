@model webclothes.Models.Order
@{
    ViewData["Title"] = "Chi tiết Đơn hàng #" + Model.Id;
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Chi tiết Đơn hàng #@Model.Id</h2>
    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-dark text-white"><i class="fas fa-user"></i> Thông tin khách hàng</div>
            <div class="card-body">
                <p><strong>Tên:</strong> @Model.CustomerName</p>
                <p><strong>SĐT:</strong> @Model.Phone</p>
                <p class="mb-4"><strong>Địa chỉ:</strong> @Model.Address</p>
                <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>

                <hr />
                <p class="mb-2"><strong>Trạng thái đơn hàng:</strong></p>
                @if (User.IsInRole("Admin") || User.IsInRole("Seller"))
                {
                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="status" class="form-select form-select-sm w-auto" style="min-width: 150px;">
                            <option value="Chờ xử lý" selected="@(Model.Status == "Chờ xử lý" ? "selected" : null)">Chờ xử lý</option>
                            <option value="Chờ lấy hàng" selected="@(Model.Status == "Chờ lấy hàng" ? "selected" : null)">Chờ lấy hàng</option>
                            <option value="Đang giao hàng" selected="@(Model.Status == "Đang giao hàng" ? "selected" : null)">Đang giao hàng</option>
                            <option value="Hoàn thành" selected="@(Model.Status == "Hoàn thành" ? "selected" : null)">Hoàn thành</option>
                            <option value="Thất bại" selected="@(Model.Status == "Thất bại" ? "selected" : null)">Thất bại</option>
                            <option value="Đã hủy" selected="@(Model.Status == "Đã hủy" ? "selected" : null)">Đã hủy</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-success">Cập nhật</button>
                    </form>
                }
                else if (User.IsInRole("Shipper"))
                {
                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <select name="status" class="form-select form-select-sm w-auto" style="min-width: 150px;">
                            <option value="Chờ lấy hàng" selected="@(Model.Status == "Chờ lấy hàng" ? "selected" : null)">Chờ lấy hàng</option>
                            <option value="Hoàn thành" selected="@(Model.Status == "Hoàn thành" ? "selected" : null)">Hoàn thành</option>
                            <option value="Thất bại" selected="@(Model.Status == "Thất bại" ? "selected" : null)">Thất bại</option>
                        </select>
                        <button type="submit" class="btn btn-sm btn-success">Cập nhật</button>
                    </form>
                }

            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white"><i class="fas fa-box"></i> Sản phẩm đã đặt</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0 text-center align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th>Kích cỡ</th>
                            <th>Đơn giá</th>
                            <th>Số lượng</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>
                                <td class="text-start">@item.Product?.Name</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Size))
                                    {
                                        <span class="badge bg-secondary">@item.Size</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@item.Price.ToString("N0") đ</td>
                                <td>x @item.Quantity</td>
                                <td class="fw-bold">@((item.Price * item.Quantity).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td colspan="4" class="text-end">TỔNG CỘNG:</td>
                            <td class="text-danger fs-5">@Model.TotalAmount.ToString("N0") đ</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>