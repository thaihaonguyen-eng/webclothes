@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>
@{
    ViewData["Title"] = "Quản lý tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
    var allRoles = ViewBag.AllRoles as List<string>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách Tài khoản người dùng</h2>
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Tìm kiếm Email, Username..." />
        <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-search"></i></button>
    </form>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive shadow-sm rounded">
    <table class="table table-hover table-bordered text-center align-middle mb-0">
        <thead class="table-dark">
            <tr>
                <th>Email / Tài khoản</th>
                <th>Tên đăng nhập</th>
                <th>Quyền hạn hiện tại</th>
                <th>Thay đổi quyền</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td class="text-start ps-3">@user.Email</td>
                    <td>@user.UserName</td>
                    <td>
                        @if (userRoles != null && userRoles.ContainsKey(user.Id))
                        {
                            foreach (var role in userRoles[user.Id])
                            {
                                <span class="badge bg-info text-dark">@role</span>
                            }
                        }
                    </td>
                    <td>
                        <form asp-action="UpdateRole" method="post" class="d-flex gap-2 justify-content-center">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="roleName" class="form-select form-select-sm" style="width: auto;">
                                <option value="None">-- Không có --</option>
                                @foreach (var role in allRoles ?? new List<string>())
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Cập nhật</button>
                        </form>
                    </td>
                    <td>
                        @if (user.LockoutEnd != null && user.LockoutEnd > DateTime.Now)
                        {
                            <span class="badge bg-danger">Đã khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Hoạt động</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
