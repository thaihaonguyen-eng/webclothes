@model IEnumerable<webclothes.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách Danh mục</h2>
    <div class="d-flex gap-2">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2" placeholder="Tìm kiếm..." />
            <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-search"></i></button>
        </form>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm danh mục mới</a>
    </div>
</div>

<table class="table table-hover table-bordered text-center align-middle">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td class="fw-bold">@item.Name</td>
                <td class="text-start">@item.Description</td>
                <td>
                    @if (item.IsDeleted)
                    {
                        <span class="badge bg-danger">Đã ẩn</span>
                    }
                    else
                    {
                        <span class="badge bg-success">Hiển thị</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i> Sửa</a>
                </td>
            </tr>
        }
    </tbody>
</table>