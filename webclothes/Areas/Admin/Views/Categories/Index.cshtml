@model IEnumerable<webclothes.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Danh sách danh mục</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i> Thêm mới</a>
</div>

<div class="card shadow">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="thead-dark">
                <tr>
                    <th>Tên danh mục</th>
                    <th>Danh mục cha</th>
                    <th width="250">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @if (item.ParentCategoryId != null)
                            {
                                <i class="fa fa-level-up-alt text-muted fa-rotate-90 ms-3 me-2"></i>
                            }
                            <strong>@item.Name</strong>
                        </td>
                        <td>
                            @(item.ParentCategory != null ? item.ParentCategory.Name : "-")
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white"><i class="fa fa-edit"></i> Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="fa fa-trash"></i> Xóa</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>