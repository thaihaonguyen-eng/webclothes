@{
    ViewData["Title"] = "Bảng điều khiển";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="mb-4">Tổng quan kinh doanh</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow-sm">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase small opacity-75">Tổng doanh thu</div>
                        <h4 class="fw-bold mt-1 mb-0">@ViewBag.TotalRevenue.ToString("N0") đ</h4>
                    </div>
                    <i class="fas fa-money-bill-wave fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow-sm">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase small opacity-75">Tổng đơn hàng</div>
                        <h4 class="fw-bold mt-1 mb-0">@ViewBag.TotalOrders</h4>
                    </div>
                    <i class="fas fa-shopping-basket fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning shadow-sm">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase small opacity-75">Chờ xử lý</div>
                        <h4 class="fw-bold mt-1 mb-0">@ViewBag.PendingOrders</h4>
                    </div>
                    <i class="fas fa-clock fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info shadow-sm">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="text-uppercase small opacity-75">Sản phẩm</div>
                        <h4 class="fw-bold mt-1 mb-0">@ViewBag.TotalProducts</h4>
                    </div>
                    <i class="fas fa-tshirt fs-1 opacity-25"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <h6 class="fw-bold mb-4">Biểu đồ doanh thu năm @DateTime.Now.Year</h6>
                <canvas id="revenueChart" style="max-height: 350px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-bold py-3">
                <i class="fas fa-tasks me-2"></i>Hoạt động hệ thống gần đây
            </div>
            <div class="card-body p-0">
                <div class="list-group list-group-flush">
                    @if (ViewBag.RecentActivities != null)
                    {
                        foreach (var activity in (List<webclothes.Models.OrderStatusHistory>)ViewBag.RecentActivities)
                        {
                            <div class="list-group-item p-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge @(activity.Status == "Hoàn thành" ? "bg-success" : activity.Status == "Đã hủy" || activity.Status == "Thất bại" ? "bg-danger" : "bg-primary")" style="font-size: 0.7rem;">
                                        @activity.Status
                                    </span>
                                    <small class="text-muted">@activity.ChangedAt.ToString("HH:mm dd/MM")</small>
                                </div>
                                <div class="small">
                                    <strong>@activity.ChangedBy</strong> đã cập nhật Đơn hàng <strong>#@activity.OrderId</strong>
                                </div>
                                @if (!string.IsNullOrEmpty(activity.Note))
                                {
                                    <div class="small text-muted mt-1 italic">"@activity.Note"</div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">Chưa có hoạt động nào.</div>
                    }
                </div>
            </div>
            <div class="card-footer bg-white text-center">
                <a href="/Admin/Orders" class="btn btn-sm btn-link text-decoration-none">Xem tất cả đơn hàng</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('revenueChart').getContext('2d');
        const chartData = "@ViewBag.ChartData".split(',').map(Number);

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9', 'T10', 'T11', 'T12'],
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: chartData,
                    borderColor: '#0d6efd',
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 5,
                    pointBackgroundColor: '#0d6efd'
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) { return value.toLocaleString() + ' đ'; }
                        }
                    }
                }
            }
        });
    </script>
}