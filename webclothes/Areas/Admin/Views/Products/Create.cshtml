@model webclothes.Models.Product
@{
    ViewData["Title"] = "Thêm Sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm mt-4">
            <div class="card-header bg-dark text-white">
                <h4 class="mb-0">Đăng bán sản phẩm mới</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm *</label>
                        <input asp-for="Name" class="form-control" required placeholder="Ví dụ: Áo sơ mi nam cao cấp" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả sản phẩm *</label>
                        <textarea asp-for="Description" class="form-control" rows="4" required placeholder="Nhập mô tả sản phẩm của bạn"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Danh mục *</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="@ViewBag.Categories" required>
                                <option value="">-- Chọn --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Giá bán (VNĐ) *</label>
                            <input asp-for="Price" type="number" class="form-control" required placeholder="VD: 250000" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Tồn kho *</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" required placeholder="VD: 100" min="0" />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Kích cỡ (Size)</label>
                        <input asp-for="Size" class="form-control" placeholder="VD: S, M, L, XL, XXL" />
                        <small class="text-muted">Nhập các size cách nhau bằng dấu phẩy</small>
                    </div>

                    <div class="card mb-4 border-danger border-opacity-25">
                        <div class="card-header bg-danger bg-opacity-10 fw-bold text-danger">
                            <i class="fas fa-fire me-1"></i> Flash Sale (Tùy chọn)
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Giá Sale (VNĐ)</label>
                                    <input asp-for="SalePrice" type="number" class="form-control" placeholder="Để trống nếu không Sale" min="0" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-bold">Kết thúc Sale</label>
                                    <input asp-for="SaleEndDate" type="datetime-local" class="form-control" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                        <input type="file" name="imageFile" class="form-control mb-2" accept="image/*,.avif,.webp" />
                        <small class="text-muted d-block mb-1">Thêm các ảnh phụ (Gallery):</small>
                        <input type="file" name="galleryFiles" class="form-control" accept="image/*,.avif,.webp" multiple />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success px-4"><i class="fas fa-save"></i> Lưu sản phẩm</button>
                        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>